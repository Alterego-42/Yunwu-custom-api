{
  "name": "@yunwu/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "dev:api": "pnpm dev",
    "dev:worker": "nest start --watch --entryFile worker",
    "build": "pnpm prisma:generate && pnpm --filter @yunwu/shared build && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:api": "pnpm start",
    "start:worker": "node dist/worker.js",
    "lint": "pnpm --filter @yunwu/shared build && tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "@yunwu/shared": "workspace:*",
    "bullmq": "^5.76.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "5.7.3"
  }
}
