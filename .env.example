NODE_ENV=development
PORT=3000
WEB_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:3000/api

# Prisma / PostgreSQL
# Prisma schema 路径由 apps/api 的 Prisma 配置或 package scripts 管理；运行时必需 DATABASE_URL。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yunwu_platform?schema=public

# BullMQ / Redis 任务队列（API 入队 + Worker 消费必需）
REDIS_URL=redis://localhost:6379
TASK_QUEUE_ENABLED=true
TASK_QUEUE_NAME=yunwu-image-tasks

# Worker 进程
# 正式拆分后：API 进程不消费任务，Worker 进程消费同一个 TASK_QUEUE_NAME。
# TASK_QUEUE_CONCURRENCY 保留兼容旧实现；新实现优先读取 TASK_WORKER_CONCURRENCY。
TASK_QUEUE_CONCURRENCY=2
TASK_WORKER_ENABLED=true
TASK_WORKER_CONCURRENCY=2

# 对象存储模式：local | minio | s3
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./storage
PUBLIC_ASSET_BASE_URL=http://localhost:3000/api/assets

# MinIO（本地联调推荐）
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=yunwu-assets
MINIO_USE_SSL=false

# 可选：显式覆盖 MinIO 对外访问地址
MINIO_PUBLIC_BASE_URL=

# S3 兼容对象存储（生产/真实存储预留）
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=

YUNWU_BASE_URL=https://yunwu.ai
YUNWU_API_KEY=

# 本地内置账号
AUTH_ADMIN_EMAIL=admin@yunwu.local
AUTH_ADMIN_PASSWORD=admin123456
AUTH_ADMIN_DISPLAY_NAME=Administrator
AUTH_DEMO_EMAIL=demo@yunwu.local
AUTH_DEMO_PASSWORD=demo123456
AUTH_DEMO_DISPLAY_NAME=Demo User
AUTH_SESSION_SECRET=yunwu-dev-session-secret-change-me
AUTH_COOKIE_NAME=yunwu_session
AUTH_SESSION_TTL_HOURS=168
AUTH_COOKIE_SECURE=false

# Web / CORS
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
WEB_ORIGIN=http://127.0.0.1:5173
