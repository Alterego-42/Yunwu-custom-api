{
  "name": "yunwu-custom-api",
  "version": "0.4.1",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "local:prepare": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/start-local.ps1 -Mode Prepare",
    "local:start": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/start-local.ps1 -Mode Windows",
    "local:start:manual": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/start-local.ps1 -Mode Manual",
    "local:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/stop-local.ps1",
    "local:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/stop-local.ps1 -ResetVolumes",
    "local:test": "pnpm local:test:auth && pnpm local:test:routes",
    "local:test:auth": "pnpm --filter @yunwu/api test:auth",
    "local:test:routes": "pnpm --filter @yunwu/web test:routes",
    "local:test:smoke": "node ./scripts/regression/local-smoke.mjs",
    "local:test:round3": "node ./scripts/regression/round3-acceptance.mjs",
    "local:test:browser-workspace": "node ./scripts/regression/browser-workspace-smoke.mjs",
    "local:test:semantic-image": "node ./scripts/regression/semantic-image-smoke.mjs",
    "desktop:dev": "pnpm --filter @yunwu/desktop dev",
    "desktop:build": "pnpm --filter @yunwu/desktop build",
    "desktop:typecheck": "pnpm --filter @yunwu/desktop typecheck",
    "desktop:package": "pnpm --filter @yunwu/desktop package",
    "docker:infra:up": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action infra:up",
    "docker:infra:down": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action infra:down",
    "docker:up": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action up -Build",
    "docker:down": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action down",
    "docker:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action reset",
    "docker:config": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action config",
    "docker:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action ps",
    "docker:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action logs",
    "docker:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/compose-local.ps1 -Action migrate",
    "docker:verify-instance": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/verify-instance-compose.ps1 -App"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.7.3"
    }
  }
}
